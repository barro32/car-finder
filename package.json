    "@vercel/postgres": "^0.10.0",
    "next": "^15.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
